<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>dist</id>
    <formats>
        <format>tar.gz</format>
        <format>zip</format>
    </formats>
    <includeBaseDirectory>true</includeBaseDirectory>
    <baseDirectory>kylin-sql-${project.version}</baseDirectory>

    <dependencySets>
        <dependencySet>
            <outputDirectory>lib</outputDirectory>
            <unpack>false</unpack>
            <scope>runtime</scope>
            <useProjectArtifact>false</useProjectArtifact>
        </dependencySet>
    </dependencySets>

    <fileSets>
        <!-- 启动脚本 -->
        <fileSet>
            <directory>src/main/assembly</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>kylin-sql.sh</include>
                <include>kylin-sql.bat</include>
                <include>kylin-sql.vbs</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>
        <!-- 桌面集成 -->
        <fileSet>
            <directory>src/main/assembly</directory>
            <outputDirectory>/</outputDirectory>
            <includes>
                <include>kylin-sql.desktop</include>
                <include>install-desktop.sh</include>
                <include>install-shortcut.vbs</include>
            </includes>
            <fileMode>0755</fileMode>
        </fileSet>
        <!-- 图标 -->
        <fileSet>
            <directory>src/main/assembly/logo</directory>
            <outputDirectory>/logo</outputDirectory>
        </fileSet>
    </fileSets>
</assembly>
