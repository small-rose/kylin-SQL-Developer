    // -- Color Swatch --

    static class ColorSwatch extends JPanel {
        private Color color = Color.GRAY;

        ColorSwatch(String key) {
            setPreferredSize(new Dimension(28, 18));
            setOpaque(true);
            Color def = ThemeManager.getInstance().getCurrentTheme().resolve(key);
            if (def != null) color = def;
        }

        void setColor(Color c) {
            this.color = c != null ? c : Color.GRAY;
            repaint();
        }

        @Override
        protected void paintComponent(Graphics g) {
            g.setColor(color);
            g.fillRect(0, 0, getWidth(), getHeight());
            g.setColor(Color.DARK_GRAY);
            g.drawRect(0, 0, getWidth() - 1, getHeight() - 1);
        }
    }

    public SettingsDialog(Frame owner, FormatOptions formatOptions) {
        super(owner, "\u8BBE\u7F6E", true);
        this.owner = owner;
        this.formatOptions = formatOptions;

        ThemeManager thm = ThemeManager.getInstance();
        originalTheme = thm.getCurrentTheme();
        originalOverrides.putAll(thm.getOverrideHexMap());
        originalFormatMap.putAll(formatOptions.toMap());

        initEditedOverrides();
        initComponents();
        loadValues();
        setSize(780, 560);
        setLocationRelativeTo(owner);
    }

    private void initEditedOverrides() {
        editedOverrides.clear();
        ThemeManager thm = ThemeManager.getInstance();
        var hexMap = thm.getOverrideHexMap();
        for (var e : hexMap.entrySet()) {
            editedOverrides.put(e.getKey(), thm.resolve(e.getKey()));
        }
    }

    // -- Tree node helpers --

    private static class ColorGroupNode {
        final ColorGroup group;
        ColorGroupNode(ColorGroup group) { this.group = group; }
        @Override public String toString() { return group.name; }
    }

    private static class LeafNode {
        final String name;
        final String cardKey;
        LeafNode(String name, String cardKey) { this.name = name; this.cardKey = cardKey; }
        @Override public String toString() { return name; }
    }

    private void initComponents() {
        setLayout(new BorderLayout());

        // -- Tree --
        DefaultMutableTreeNode root = new DefaultMutableTreeNode();
        DefaultMutableTreeNode themeNode = new DefaultMutableTreeNode(new LeafNode("\u4E3B\u9898", "theme"));
        root.add(themeNode);

        DefaultMutableTreeNode personalNode = new DefaultMutableTreeNode("\u4E2A\u6027\u5316");
        for (var group : COLOR_GROUPS) {
            personalNode.add(new DefaultMutableTreeNode(new ColorGroupNode(group)));
        }
        root.add(personalNode);

        DefaultMutableTreeNode fmtNode = new DefaultMutableTreeNode(new LeafNode("SQL \u683C\u5F0F\u5316", "format"));
        root.add(fmtNode);

        tree = new JTree(new DefaultTreeModel(root));
        tree.setRootVisible(false);
        tree.setShowsRootHandles(true);
        tree.setRowHeight(24);
        // Use L&F default label font for tree text
        tree.setCellRenderer(new DefaultTreeCellRenderer() {
            {
                setLeafIcon(null);
                setOpenIcon(null);
                setClosedIcon(null);
            }
            @Override
            public Component getTreeCellRendererComponent(JTree tree, Object value, boolean sel,
                                                          boolean expanded, boolean leaf, int row, boolean hasFocus) {
                Component c = super.getTreeCellRendererComponent(tree, value, sel, expanded, leaf, row, hasFocus);
                if (c instanceof JLabel lbl) {
                    if (value instanceof DefaultMutableTreeNode node) {
                        Object user = node.getUserObject();
                        if (user instanceof LeafNode ln) lbl.setText(ln.name);
                        else if (user instanceof ColorGroupNode cgn) lbl.setText(cgn.group.name);
                        else lbl.setText(user.toString());
                    }
                }
                return c;
            }
        });
        tree.addTreeSelectionListener(this::onTreeSelect);

        JScrollPane treeScroll = new JScrollPane(tree);
        treeScroll.setPreferredSize(new Dimension(200, 0));
        this.treeScroll = treeScroll;
        treeScroll.setBorder(BorderFactory.createMatteBorder(0, 0, 0, 1, ThemeManager.getInstance().resolve("border.light")));

        // -- Right panels --
        rightPanel = new JPanel(new CardLayout());
        rightPanel.add(buildThemePanel(), "theme");
        rightPanel.add(buildFormatPanel(), "format");
        for (var group : COLOR_GROUPS) {
            rightPanel.add(buildColorGroupPanel(group), "color_" + group.name);
        }

        // -- Split --
        split = new JSplitPane(JSplitPane.HORIZONTAL_SPLIT, treeScroll, rightPanel);
        split.setResizeWeight(0.15);
        split.setBorder(null);
        split.setDividerLocation(180);
        add(split, BorderLayout.CENTER);

        // -- Bottom buttons --
        btnPanel = new JPanel(new FlowLayout(FlowLayout.RIGHT, 8, 6));
        JButton applyBtn = new JButton("\u5E94\u7528");
        applyBtn.addActionListener(e -> { saveToConfig(); });
        JButton saveBtn = new JButton("\u4FDD\u5B58");
        saveBtn.addActionListener(e -> { saveToConfig(); dispose(); });
        JButton cancelBtn = new JButton("\u53D6\u6D88");
        cancelBtn.addActionListener(e -> { restoreOriginal(); dispose(); });
        btnPanel.add(applyBtn);
        btnPanel.add(saveBtn);
        btnPanel.add(cancelBtn);
        add(btnPanel, BorderLayout.SOUTH);

        // Select first node
        tree.setSelectionRow(0);
    }

