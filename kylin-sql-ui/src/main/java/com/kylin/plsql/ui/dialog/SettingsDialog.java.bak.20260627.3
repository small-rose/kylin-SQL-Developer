    private static JPanel buildTabPanel(JComponent... rows) {
        JPanel p = new JPanel(new GridBagLayout());
        p.setBorder(BorderFactory.createEmptyBorder(12, 8, 8, 8));
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.insets = new Insets(3, 4, 3, 4);
        gbc.anchor = GridBagConstraints.WEST;
        for (int i = 0; i < rows.length; i++) {
            JComponent row = rows[i];
            if (row instanceof JCheckBox check) {
                gbc.gridx = 0; gbc.gridy = i; gbc.gridwidth = 2;
                p.add(check, gbc);
                gbc.gridwidth = 1;
            } else if (row instanceof JPanel panel) {
                // label + component pair
                Component[] comps = panel.getComponents();
                if (comps.length >= 2) {
                    gbc.gridx = 0; gbc.gridy = i;
                    comps[0].setFont(UIManager.getFont("Label.font").deriveFont(12f));
                    p.add(comps[0], gbc);
                    gbc.gridx = 1;
                    comps[1].setPreferredSize(new Dimension(180, 26));
                    p.add(comps[1], gbc);
                }
            }
        }
        // top-left anchor
        JPanel top = new JPanel(new BorderLayout());
        top.add(p, BorderLayout.NORTH);
        return top;
    }

    private static JPanel row(String label, JComponent comp) {
        JPanel p = new JPanel(new FlowLayout(FlowLayout.LEFT, 0, 0));
        if (!label.isEmpty()) {
            p.add(new JLabel(label));
        }
        p.add(comp);
        return p;
    }

    // -- Color Group Panels --

    private JPanel buildColorGroupPanel(ColorGroup group) {
        JPanel p = new JPanel(new BorderLayout());
        p.setBorder(BorderFactory.createEmptyBorder(8, 8, 8, 8));

        JLabel title = new JLabel(group.name);
        title.setFont(title.getFont().deriveFont(Font.BOLD, 14f));
        p.add(title, BorderLayout.NORTH);

        JPanel listPanel = new JPanel(new GridBagLayout());
        listPanel.setBorder(BorderFactory.createEmptyBorder(8, 0, 0, 0));
        GridBagConstraints gbc = new GridBagConstraints();
        gbc.fill = GridBagConstraints.HORIZONTAL;
        gbc.anchor = GridBagConstraints.NORTHWEST;
        gbc.insets = new Insets(2, 0, 2, 0);

        int row = 0;
        for (var item : group.items) {
            gbc.gridx = 0; gbc.gridy = row; gbc.weightx = 0;
            JLabel keyLabel = new JLabel("  " + item.desc + " / " + item.key);
            keyLabel.setFont(UIManager.getFont("Label.font").deriveFont(12f));
            keyLabel.setBorder(DEFAULT_CELL_BORDER);
            listPanel.add(keyLabel, gbc);

            gbc.gridx = 1; gbc.weightx = 0;
            ColorSwatch swatch = new ColorSwatch(item.key);
            Color def = editedOverrides.containsKey(item.key)
                ? editedOverrides.get(item.key)
                : ThemeManager.getInstance().getCurrentTheme().resolve(item.key);
            if (def != null) swatch.setColor(def);
            swatches.put(item.key, swatch);
            listPanel.add(swatch, gbc);

            gbc.gridx = 2; gbc.weightx = 1;
            JPanel btnPanel = new JPanel(new FlowLayout(FlowLayout.LEFT, 4, 0));
            btnPanel.setOpaque(false);
            JButton pickBtn = new JButton("\u4FEE\u6539");
            pickBtn.setFont(UIManager.getFont("Label.font").deriveFont(10f));
            pickBtn.addActionListener(e -> pickColor(item.key));
            JButton resetBtn = new JButton("\u91CD\u7F6E");
            resetBtn.setFont(UIManager.getFont("Label.font").deriveFont(10f));
            resetBtn.addActionListener(e -> resetColor(item.key));
            btnPanel.add(pickBtn);
            btnPanel.add(resetBtn);
            listPanel.add(btnPanel, gbc);
            row++;
        }

        JScrollPane scroll = new JScrollPane(listPanel);
        scroll.setBorder(BorderFactory.createEmptyBorder());
        scroll.getVerticalScrollBar().setUnitIncrement(16);
        // Force viewport to top-left
        JPanel topWrapper = new JPanel(new BorderLayout());
        topWrapper.add(listPanel, BorderLayout.NORTH);
        scroll.setViewportView(topWrapper);
        p.add(scroll, BorderLayout.CENTER);

        // Reset group button
        JPanel bottomBar = new JPanel(new FlowLayout(FlowLayout.LEFT));
        JButton resetGroupBtn = new JButton("\u91CD\u7F6E\u672C\u7EC4");
        resetGroupBtn.addActionListener(e -> {
            for (var item : group.items) {
                resetColor(item.key);
            }
        });
        bottomBar.add(resetGroupBtn);
        p.add(bottomBar, BorderLayout.SOUTH);

        return p;
    }

    // -- Actions --

    private void onTreeSelect(TreeSelectionEvent e) {
        TreePath path = e.getNewLeadSelectionPath();
        if (path == null) return;
        Object last = path.getLastPathComponent();
        if (!(last instanceof DefaultMutableTreeNode node)) return;
        Object user = node.getUserObject();

        String cardKey;
        if (user instanceof LeafNode ln) {
            cardKey = ln.cardKey;
        } else if (user instanceof ColorGroupNode cgn) {
            cardKey = "color_" + cgn.group.name;
        } else {
            return;
        }
        ((CardLayout) rightPanel.getLayout()).show(rightPanel, cardKey);
    }

    private void onThemeChanged() {
        int idx = themeCombo.getSelectedIndex();
        AppTheme[] themes = AppTheme.values();
        if (idx < 0 || idx >= themes.length) return;
        AppTheme selected = themes[idx];
        if (selected == ThemeManager.getInstance().getCurrentTheme()) return;

        // Save tree selection state (UI update may reset it)
        TreePath selPath = tree.getSelectionPath();

        // Preview: switch in memory + L&F
        ThemeManager.getInstance().switchTo(selected);
        if ("DARK".equals(selected.config("flatlaf"))) {
            try { UIManager.setLookAndFeel(new com.formdev.flatlaf.FlatDarculaLaf()); }
            catch (Exception ignored) {}
        } else {
            try { UIManager.setLookAndFeel(new com.formdev.flatlaf.FlatLightLaf()); }
            catch (Exception ignored) {}
        }

        // Set tree colors before UI update (installDefaults may set LAF default)
        tree.setBackground(selected.resolve("list.bg"));
        tree.setForeground(selected.resolve("list.fg"));

        SwingUtilities.updateComponentTreeUI(this);
        if (owner != null) SwingUtilities.updateComponentTreeUI(owner);
        if (owner instanceof com.kylin.plsql.ui.MainFrame mf) {
            mf.reapplyTheme();
            // Second pass after L&F fully settles
            javax.swing.SwingUtilities.invokeLater(() -> {
                mf.revalidate();
                mf.repaint();
            });
        }

        // Restore tree selection
        if (selPath != null) {
            tree.setSelectionPath(selPath);
            tree.scrollPathToVisible(selPath);
        }

        // Update tree renderer UI (not a child component, not reached by updateComponentTreeUI)
        var r = tree.getCellRenderer();
        if (r instanceof DefaultTreeCellRenderer dtr) {
            dtr.updateUI();
        }
        // Re-apply tree colors after UI update (in case installDefaults overrode them)
        tree.setBackground(selected.resolve("list.bg"));
        tree.setForeground(selected.resolve("list.fg"));
        tree.repaint();

        // Update tree scroll border and hint labels with theme colors
        if (treeScroll != null) {
            treeScroll.setBorder(BorderFactory.createMatteBorder(0, 0, 0, 1, selected.resolve("border.light")));
        }
        if (themeHint1 != null) themeHint1.setForeground(selected.resolve("fg.muted"));
        if (themeHint2 != null) themeHint2.setForeground(selected.resolve("fg.muted"));

        // Restore split divider after UI update (can shift)
        if (split != null) split.setDividerLocation(180);

        // Force right panel cards to repaint with new theme
        for (Component c : rightPanel.getComponents()) {
            c.repaint();
            c.revalidate();
        }

        // Force bottom button panel to repaint with new theme
        if (btnPanel != null) {
            btnPanel.repaint();
            btnPanel.revalidate();
        }

        // Update color swatches with current theme colors
        for (var e : swatches.entrySet()) {
            Color c = editedOverrides.containsKey(e.getKey())
                ? editedOverrides.get(e.getKey())
                : ThemeManager.getInstance().getCurrentTheme().resolve(e.getKey());
            if (c != null) e.getValue().setColor(c);
        }

        repaint();
        revalidate();
    }

    private void pickColor(String key) {
        Color current = editedOverrides.containsKey(key)
            ? editedOverrides.get(key)
            : ThemeManager.getInstance().getCurrentTheme().resolve(key);
        Color chosen = JColorChooser.showDialog(this, "\u9009\u62E9\u989C\u8272 - " + key, current);
        if (chosen != null) {
            editedOverrides.put(key, chosen);
            ColorSwatch sw = swatches.get(key);
            if (sw != null) sw.setColor(chosen);
            ThemeManager.getInstance().setOverride(key, chosen);
            if (owner instanceof com.kylin.plsql.ui.MainFrame mf) mf.reapplyTheme();
        }
    }

    private void resetColor(String key) {
        editedOverrides.remove(key);
        Color def = ThemeManager.getInstance().getCurrentTheme().resolve(key);
        ColorSwatch sw = swatches.get(key);
        if (sw != null) sw.setColor(def);
        ThemeManager.getInstance().removeOverride(key);
        if (owner instanceof com.kylin.plsql.ui.MainFrame mf) mf.reapplyTheme();
    }

    // ── Profile actions ──

    private void onProfileSelected() {
        String name = (String) profileCombo.getSelectedItem();
        if (name == null) return;
        formatOptions.switchTo(name);
        applyFormatOptionsToUI(formatOptions);
    }

    private void onSaveAsProfile() {
        String name = JOptionPane.showInputDialog(this, "\u8F93\u5165\u914D\u7F6E\u65B9\u6848\u540D\u79F0:");
        if (name == null || name.isBlank()) return;
        readFormatOptionsFromUI(formatOptions);
        formatOptions.saveAs(name.trim());
        refreshProfileCombo();
    }

    private void onDeleteProfile() {
        String name = (String) profileCombo.getSelectedItem();
        if (name == null) return;
        if ("\u9ED8\u8BA4 (Oracle)".equals(name)) {
            JOptionPane.showMessageDialog(this, "\u9ED8\u8BA4\u914D\u7F6E\u4E0D\u80FD\u5220\u9664");
            return;
        }
        formatOptions.deleteProfile(name);
        refreshProfileCombo();
    }

    private void onExportProfile() {
        String name = (String) profileCombo.getSelectedItem();
        if (name == null) return;
        String json = formatOptions.exportProfile(name, true);
        JTextArea ta = new JTextArea(json, 6, 40);
        ta.setEditable(false);
        ta.setFont(new Font("Monospaced", Font.PLAIN, 12));
        JOptionPane.showMessageDialog(this, new JScrollPane(ta), "\u5BFC\u51FA - " + name, JOptionPane.PLAIN_MESSAGE);
    }

    private void onImportProfile() {
        String json = JOptionPane.showInputDialog(this, "\u8F93\u5165 JSON \u914D\u7F6E:");
        if (json == null || json.isBlank()) return;
        String name = JOptionPane.showInputDialog(this, "\u8F93\u5165\u914D\u7F6E\u65B9\u6848\u540D\u79F0:");
        if (name == null || name.isBlank()) return;
        formatOptions.importProfile(name.trim(), json.trim());
        refreshProfileCombo();
    }

    private void refreshProfileCombo() {
        profileCombo.removeAllItems();
        for (String name : formatOptions.getProfiles().keySet()) {
            profileCombo.addItem(name);
        }
        profileCombo.setSelectedItem(formatOptions.getActiveProfile());
    }

    // ── Format UI ↔ FormatOptions sync ──

    private void readFormatOptionsFromUI(FormatOptions opts) {
        opts.setKeywordCase((FormatOptions.KeywordCase) keywordCaseCombo.getSelectedItem());
        opts.setIndentSize((Integer) indentSizeSpinner.getValue());
        opts.setMaxLineWidth((Integer) maxLineWidthSpinner.getValue());
        opts.setLineEnding((String) lineEndingCombo.getSelectedItem());
        opts.setSelectColumnMode((SelectColumnMode) selectColumnModeCombo.getSelectedItem());
        opts.setFromClauseNewline(fromClauseNewlineCheck.isSelected());
        opts.setJoinOnNewline(joinOnNewlineCheck.isSelected());
        opts.setJoinOnAlign(joinOnAlignCheck.isSelected());
        opts.setWhereAndPosition((WhereAndPosition) whereAndPositionCombo.getSelectedItem());
        opts.setCommaPosition((CommaPosition) commaPositionCombo.getSelectedItem());
        opts.setInsertColumnModeCompact(insertColumnModeCompactCheck.isSelected());
        opts.setUpdateSetAlign(updateSetAlignCheck.isSelected());
        opts.setThenOnNewLine(thenOnNewLineCheck.isSelected());
        opts.setLoopOnNewLine(loopOnNewLineCheck.isSelected());
        opts.setElseOnNewLine(elseOnNewLineCheck.isSelected());
        opts.setExceptionAlign((ExceptionAlign) exceptionAlignCombo.getSelectedItem());
        opts.setDeclarationAlign(declarationAlignCheck.isSelected());
        opts.setParameterListMode((ParameterListMode) parameterListModeCombo.getSelectedItem());
        opts.setParenthesisSpacing((ParenthesisSpacing) parenthesisSpacingCombo.getSelectedItem());
        opts.setColumnDefAlign(columnDefAlignCheck.isSelected());
        opts.setStorageClauseFormat((StorageClauseFormat) storageClauseFormatCombo.getSelectedItem());
    }

    private void applyFormatOptionsToUI(FormatOptions opts) {
        keywordCaseCombo.setSelectedItem(opts.getKeywordCase());
        indentSizeSpinner.setValue(opts.getIndentSize());
        maxLineWidthSpinner.setValue(opts.getMaxLineWidth());
        lineEndingCombo.setSelectedItem(opts.getLineEnding());
        selectColumnModeCombo.setSelectedItem(opts.getSelectColumnMode());
        fromClauseNewlineCheck.setSelected(opts.isFromClauseNewline());
        joinOnNewlineCheck.setSelected(opts.isJoinOnNewline());
        joinOnAlignCheck.setSelected(opts.isJoinOnAlign());
        whereAndPositionCombo.setSelectedItem(opts.getWhereAndPosition());
        commaPositionCombo.setSelectedItem(opts.getCommaPosition());
        insertColumnModeCompactCheck.setSelected(opts.isInsertColumnModeCompact());
        updateSetAlignCheck.setSelected(opts.isUpdateSetAlign());
        thenOnNewLineCheck.setSelected(opts.isThenOnNewLine());
        loopOnNewLineCheck.setSelected(opts.isLoopOnNewLine());
        elseOnNewLineCheck.setSelected(opts.isElseOnNewLine());
        exceptionAlignCombo.setSelectedItem(opts.getExceptionAlign());
        declarationAlignCheck.setSelected(opts.isDeclarationAlign());
        parameterListModeCombo.setSelectedItem(opts.getParameterListMode());
        parenthesisSpacingCombo.setSelectedItem(opts.getParenthesisSpacing());
        columnDefAlignCheck.setSelected(opts.isColumnDefAlign());
        storageClauseFormatCombo.setSelectedItem(opts.getStorageClauseFormat());
    }

    // -- Save / Cancel --

    private void saveToConfig() {
        ThemeManager thm = ThemeManager.getInstance();

        // Save theme + overrides
        thm.saveToConfig(owner instanceof com.kylin.plsql.ui.MainFrame mf ? mf.getConfigManager() : null);

        // Save format options
        readFormatOptionsFromUI(formatOptions);

        if (owner instanceof com.kylin.plsql.ui.MainFrame mf) {
            SwingUtilities.updateComponentTreeUI(mf);
            mf.reapplyTheme();
        }
    }

    private void restoreOriginal() {
        ThemeManager thm = ThemeManager.getInstance();

        // Restore theme
        if (thm.getCurrentTheme() != originalTheme) {
            thm.switchTo(originalTheme);
            if ("DARK".equals(originalTheme.config("flatlaf"))) {
                try { UIManager.setLookAndFeel(new com.formdev.flatlaf.FlatDarculaLaf()); }
                catch (Exception ignored) {}
            } else {
                try { UIManager.setLookAndFeel(new com.formdev.flatlaf.FlatLightLaf()); }
                catch (Exception ignored) {}
            }
            SwingUtilities.updateComponentTreeUI(this);
            if (owner != null) SwingUtilities.updateComponentTreeUI(owner);
        }

        // Restore overrides
        thm.loadOverrideHexMap(originalOverrides);

        // Restore format options
        FormatOptions restored = FormatOptions.fromMap(originalFormatMap);
        formatOptions.copyFrom(restored);
        formatOptions.setActiveProfile(restored.getActiveProfile());
        applyFormatOptionsToUI(formatOptions);
        refreshProfileCombo();

        if (owner instanceof com.kylin.plsql.ui.MainFrame mf) mf.reapplyTheme();
    }

    private void loadValues() {
        ThemeManager thm = ThemeManager.getInstance();
        themeCombo.setSelectedIndex(thm.getCurrentTheme().ordinal());
        refreshProfileCombo();
        applyFormatOptionsToUI(formatOptions);
    }
}
